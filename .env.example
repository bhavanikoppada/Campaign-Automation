# ── Google Sheets ──────────────────────────────────────────────────────────────
# Paste your entire service account JSON as a single line (stringify the JSON)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# Your Google Sheet ID (from the URL)
SHEET_ID=166dxm8lGoJu2L83JfYc11G5Y8cZZZeMMbSHpsUyV1kI

# Sheet tab name (default: Sheet1)
SHEET_NAME=Sheet1

# ── N8N ────────────────────────────────────────────────────────────────────────
# Production webhook — works 24/7 once the workflow is Active (runs show in Executions tab)
N8N_WEBHOOK=https://academyss.app.n8n.cloud/webhook/scheduled-campaign-v1
# Test webhook — animates the canvas, but fires once per "Execute workflow" click
N8N_WEBHOOK_TEST=https://academyss.app.n8n.cloud/webhook-test/scheduled-campaign-v1

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
POLL_MS=60000
