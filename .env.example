CAMPAIGN_ID=scheduled-campaign
PORT=3000

# Scheduler: polls sheet every 60s for Run Trigger=Scheduler + Run Type=Schedule
SCHEDULER_ENABLED=true
SCHEDULER_POLL_MS=60000
SCHEDULER_TIMEZONE=Asia/Kolkata
REQUIRE_APPROVED=true
DONE_STATUS=Done
TRIGGERED_STATUS=Triggered
